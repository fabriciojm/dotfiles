
set input-meta on
set convert-meta off
set bell-style none
$if Bash
"\C-xssh": "/usr/bin/ssh "
"\C-xscp": "/usr/bin/scp "
"\C-xsu":  "/usr/bin/su "
"\C-xdo":  "/usr/bin/sudo "
$endif

set editing-mode vi
set keymap vi-insert
"\C-l": clear-screen
"\C-e": end-of-line
"\C-a": beginning-of-line
"\C-u": kill-line
